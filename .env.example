# ═══ CRYPTOPREDICT BACKEND — ENV ═══
# Copia questo file in .env e compila con i tuoi valori

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Security
SECRET_KEY=run-openssl-rand-hex-32
ADMIN_TOKEN=your-admin-token

# CORS
CORS_ORIGINS=["https://your-frontend.vercel.app","http://localhost:3000"]

# ── Smart Contracts — Base Sepolia (v2) ──────────────────────────
BASE_SEPOLIA_RPC=https://gateway.tenderly.co/public/base-sepolia
PREDICTION_MARKET_ADDRESS=0x775267160f3F7fb7908A7f2a4a2b0AFe22CD9e66
POSITION_MARKET_ADDRESS=0xa241c72f7a7b120778e4fefab053c5f7e81c072a
AMM_POOL_ADDRESS=0xaa645dca8a82764db9a725ab3ac9e2caab1440d0
CPRED_TOKEN_ADDRESS=0xEc937bF3123874115EDcBBE1b3802C95f572e8E5
CPRED_PRESALE_ADDRESS=0xC881FF7f99a666372DD0B9d50A9244E6564ea2B7
PRESALE_STAKING_ADDRESS=0x6e9FE398C06E479Cd69663737415375e095c3454
MOCK_USDC_ADDRESS=0x8A54f0e841CFCA5fA654912AF33cCD121D182311
MOCK_USDT_ADDRESS=0xaBB48e1693Df04fb894843e52B239D5C5d0ab871

# Chainlink Functions
CHAINLINK_FUNCTIONS_CONSUMER=0xef5aa19b2d53a24b8e94a5b08ca2f1f63a37374b
CHAINLINK_FUNCTIONS_SUBSCRIPTION_ID=627
CHAINLINK_DON_ID=fun-base-sepolia-1

# Team wallet — signs resolveMarket() for expired markets
TEAM_WALLET_PRIVATE_KEY=your-deployer-private-key

# NOWPayments (optional)
NOWPAYMENTS_API_KEY=

# Telegram Bot (optional)
TELEGRAM_BOT_TOKEN=
